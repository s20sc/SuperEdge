BIPEDv2/
BSDS500/
NYUD/
*.tar
*.tar.gz
*.zip

# Allow only the small pinned manifests and trial CSV under data/
!data/
!data/manifests/
!data/manifests/*.txt
!data/grasp_trials/
!data/grasp_trials/*.csv

